{
  "buildCommand": "cd server && npm install && cd ../apsucore-app && npm install && npm run build",
  "outputDirectory": "apsucore-app/dist",
  "installCommand": "echo skip",
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
