# Backend API URL
# Development: leave empty (defaults to http://localhost:3001)
# Production: set to Railway backend URL
VITE_API_URL=https://apsucore-api.railway.app

# Firebase (for file uploads — optional)
VITE_FIREBASE_PROJECT_ID=apsucore-social
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_STORAGE_BUCKET=apsucore-social.appspot.com
