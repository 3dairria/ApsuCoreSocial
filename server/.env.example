# ── Database ──────────────────────────────────────────────────────
# PostgreSQL (production / Railway)
DATABASE_URL=postgresql://user:password@host:5432/apsucore

# Leave empty to use local SQLite (development only)
# DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-character-random-hex-string

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (production)
CORS_ORIGIN=https://apsucore.vercel.app

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Firebase Storage (optional, for file uploads) ─────────────────
FIREBASE_PROJECT_ID=apsucore-social
FIREBASE_STORAGE_BUCKET=apsucore-social.appspot.com
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
